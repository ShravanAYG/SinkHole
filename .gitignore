# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# ── Virtual environments ────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env/

# ── Pytest / coverage ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── Type checkers / linters ─────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/

# ── Secrets — never commit real config ──────────────────────────────────────
# Use botwall.toml.example as the template and keep real keys out of git.
# Uncomment the line below if you rename botwall.toml for local use:
# botwall.local.toml

# ── Rust / WASM build artefacts ─────────────────────────────────────────────
wasm_sdk/target/
wasm_sdk/pkg/

# ── Node (Playwright scripts) ────────────────────────────────────────────────
scripts/playwright/node_modules/
scripts/playwright/package-lock.json

# ── Editor / OS ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Temporary files ─────────────────────────────────────────────────────────
/tmp/
*.tmp
*.bak
